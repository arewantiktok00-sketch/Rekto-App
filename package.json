{
  "name": "rektoapp",
  "main": "index.js",
  "version": "1.0.0",
  "scripts": {
    "start": "react-native start",
    "start:reset": "react-native start --reset-cache",
    "clean": "rm -rf node_modules/.cache .metro-cache /tmp/metro-* /tmp/haste-* 2>/dev/null; watchman watch-del-all 2>/dev/null; echo Done.",
    "clean:full": "npm run clean; cd ios && xcodebuild clean 2>/dev/null; rm -rf build DerivedData 2>/dev/null; cd ..; cd android && ./gradlew clean 2>/dev/null; cd ..; echo Full clean done.",
    "ios": "react-native run-ios --simulator \"iPhone 17\"",
    "ios:sim": "react-native run-ios --simulator=\"iPhone 16\"",
    "ios:dev": "react-native run-ios --simulator=\"iPhone 16e\"",
    "ios:xcode": "open ios/Rekto.xcworkspace",
    "pod:install": "cd ios && pod install && cd ..",
    "android": "react-native run-android",
    "build:ios": "react-native run-ios --configuration Release",
    "dev:ios": "react-native start --reset-cache",
    "lint": "eslint .",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^5.2.8",
    "@react-native-async-storage/async-storage": "^3.0.1",
    "@react-native-community/datetimepicker": "^8.6.0",
    "@react-native-community/slider": "^5.1.2",
    "@react-native-picker/picker": "^2.11.4",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@react-navigation/native-stack": "^7.14.1",
    "@supabase/supabase-js": "^2.97.0",
    "@tanstack/react-query": "^5.90.21",
    "date-fns": "^4.1.0",
    "i18next": "^25.8.13",
    "lottie-react-native": "^7.3.6",
    "lucide-react-native": "^0.575.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^16.5.4",
    "react-native": "0.81.5",
    "react-native-bootsplash": "^7.1.0",
    "react-native-chart-kit": "^6.12.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-html-to-pdf": "^0.12.0",
    "react-native-image-picker": "^8.2.1",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-onesignal": "^5.3.1",
    "react-native-reanimated": "~3.19.0",
    "react-native-reanimated-carousel": "^4.0.3",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-share": "^12.2.6",
    "react-native-svg": "^15.15.3",
    "react-native-toast-message": "^2.3.3",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-vector-icons": "^10.2.0",
    "react-native-video": "^6.8.0",
    "react-native-web": "~0.21.0"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.28.6",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@react-native-community/cli": "latest",
    "@react-native/metro-config": "0.81.5",
    "@types/react": "~19.1.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^9.25.0",
    "metro-react-native-babel-preset": "^0.77.0",
    "patch-package": "^8.0.1",
    "typescript": "~5.9.2"
  },
  "private": true
}
